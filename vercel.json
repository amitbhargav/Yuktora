{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/app", "dest": "/app.html" },
    { "src": "/pricing", "dest": "/pricing.html" },
    { "src": "/blog", "dest": "/blog.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/404.html", "status": 404 }
  ]
}
